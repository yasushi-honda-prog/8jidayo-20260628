# タダカヨ 8時だヨ勉強会 #1 (2026-06-28) 環境設定
# このディレクトリに入ると自動的に適用されます

# GitHub アカウント設定
export GH_USER="yasushi-honda-prog"
export GH_REPO="yasushi-honda-prog/8jidayo-20260628"

# GitHubアカウントを自動切り替え
if command -v gh &> /dev/null; then
    current_user=$(gh api user --jq .login 2>/dev/null || echo "")
    if [ "$current_user" != "$GH_USER" ]; then
        gh auth switch --user "$GH_USER" 2>/dev/null && \
            echo "✓ GitHub account switched to: $GH_USER"
    fi
fi

echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "📦 Project: タダカヨ 8時だヨ勉強会 #1"
echo "🐙 GitHub:  $GH_REPO"
echo "📅 Date:    2026-06-28"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
